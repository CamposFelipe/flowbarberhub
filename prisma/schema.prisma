// FlowBarberHub — Prisma Schema
// Stack: PostgreSQL (Neon) | Auth.js v5 (NextAuth) | Stripe

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum OrganizationType {
  BARBER
  // SALON    // future
  // TATTOO   // future
}

enum PlanStatus {
  TRIAL
  ACTIVE
  BLOCKED
}

enum Role {
  OWNER
  ADMIN
  BARBER
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum TransactionType {
  SERVICE
  PRODUCT
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

// ─── Auth.js v5 (NextAuth) Tables ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  password        String?   // hashed — used for credentials provider
  role            Role      @default(BARBER)
  showAsBarber    Boolean   @default(false) // OWNER can opt into barber list
  organizationId  String?
  pendingPriceId  String?   // set at registration; cleared after payment or trial activation

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts     Account[]
  sessions     Session[]
  organization Organization? @relation(fields: [organizationId], references: [id])
  barberProfile Barber?

  @@index([organizationId])
  @@index([email])
}

// ─── Organization (Tenant Root) ───────────────────────────────────────────────

model Organization {
  id           String           @id @default(cuid())
  name         String
  slug         String           @unique
  type         OrganizationType @default(BARBER)
  planStatus   PlanStatus       @default(TRIAL)
  trialEndsAt  DateTime
  logoUrl      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  units        Unit[]
  subscription Subscription?
  clients      Client[]

  @@index([slug])
}

// ─── Unit (Physical Location) ─────────────────────────────────────────────────

model Unit {
  id             String @id @default(cuid())
  organizationId String
  name           String
  slug           String @unique // editable booking link: /[unit-slug]
  address        String?
  phone          String?
  logoUrl        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  schedules    UnitSchedule[]
  barbers      BarberUnit[]
  services     Service[]
  products     Product[]
  appointments Appointment[]
  transactions Transaction[]

  @@index([organizationId])
  @@index([slug])
}

// ─── UnitSchedule (Operating Hours per Day) ───────────────────────────────────

model UnitSchedule {
  id         String    @id @default(cuid())
  unitId     String
  dayOfWeek  DayOfWeek
  isOpen     Boolean   @default(true)
  openTime   String    // "09:00"
  closeTime  String    // "18:00"
  breakStart String?   // "12:00"
  breakEnd   String?   // "13:00"

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, dayOfWeek])
  @@index([unitId])
}

// ─── Barber (User assigned to Units with module permissions) ──────────────────

model Barber {
  id                String @id @default(cuid())
  userId            String @unique
  organizationId    String
  // Granular per-module permissions
  // e.g. { "financial": true, "products": false, "clients": true }
  modulePermissions Json   @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  units        BarberUnit[]
  appointments Appointment[]
  transactions Transaction[]
}

// ─── BarberUnit (Many-to-many: Barber ↔ Unit) ────────────────────────────────

model BarberUnit {
  id       String @id @default(cuid())
  barberId String
  unitId   String

  barber Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([barberId, unitId])
  @@index([barberId])
  @@index([unitId])
}

// ─── Client ───────────────────────────────────────────────────────────────────

model Client {
  id             String  @id @default(cuid())
  organizationId String
  name           String
  phone          String?
  email          String?
  // Links to User account if the client creates one later
  userId         String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([organizationId])
  @@index([phone])
  @@index([email])
}

// ─── Service ──────────────────────────────────────────────────────────────────

model Service {
  id              String  @id @default(cuid())
  unitId          String
  name            String
  price           Decimal @db.Decimal(10, 2)
  durationMinutes Int
  isActive        Boolean @default(true)
  description     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unit         Unit          @relation(fields: [unitId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([unitId])
}

// ─── Product ──────────────────────────────────────────────────────────────────

model Product {
  id          String  @id @default(cuid())
  unitId      String
  name        String
  price       Decimal @db.Decimal(10, 2)
  stock       Int     @default(0)
  isActive    Boolean @default(true)
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unit             Unit              @relation(fields: [unitId], references: [id], onDelete: Cascade)
  transactionItems TransactionItem[]

  @@index([unitId])
}

// ─── Appointment ──────────────────────────────────────────────────────────────

model Appointment {
  id       String @id @default(cuid())
  unitId   String
  barberId String
  serviceId String
  clientId  String? // null = anonymous booking

  // Captured for anonymous bookings; persists even if client creates account later
  clientName  String?
  clientPhone String?
  clientEmail String?

  startsAt DateTime
  endsAt   DateTime
  status   AppointmentStatus @default(SCHEDULED)
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unit         Unit          @relation(fields: [unitId], references: [id], onDelete: Cascade)
  barber       Barber        @relation(fields: [barberId], references: [id])
  service      Service       @relation(fields: [serviceId], references: [id])
  client       Client?       @relation(fields: [clientId], references: [id])
  transactions Transaction[]

  @@index([unitId])
  @@index([barberId])
  @@index([clientId])
  @@index([startsAt])
  @@index([status])
}

// ─── Transaction ──────────────────────────────────────────────────────────────

model Transaction {
  id            String          @id @default(cuid())
  unitId        String
  barberId      String
  appointmentId String
  type          TransactionType
  amount        Decimal         @db.Decimal(10, 2)
  description   String?

  createdAt DateTime @default(now())

  unit        Unit              @relation(fields: [unitId], references: [id], onDelete: Cascade)
  barber      Barber            @relation(fields: [barberId], references: [id])
  appointment Appointment       @relation(fields: [appointmentId], references: [id])
  items       TransactionItem[]

  @@index([unitId])
  @@index([barberId])
  @@index([appointmentId])
  @@index([createdAt])
}

// ─── TransactionItem (Products consumed in a service) ────────────────────────

model TransactionItem {
  id            String  @id @default(cuid())
  transactionId String
  productId     String
  quantity      Int     @default(1)
  unitPrice     Decimal @db.Decimal(10, 2)

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id])

  @@index([transactionId])
  @@index([productId])
}

// ─── Subscription (Stripe) ───────────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  organizationId       String             @unique
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  planName             String?
  status               SubscriptionStatus @default(TRIALING)
  currentPeriodEnd     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([stripeCustomerId])
}
